---
const {
  label: { Icon, text },
  href,
} = Astro.props;

const styles = {
  active: "active:bg-white active:text-black active:border-base-content",
  hover: "hover:text-primary hover:border-primary hover:text-primary",
  flex: "flex flex-row justify-center items-center gap-x-2",
  base: "border-1 border-base-content/25 bg-base-100/50 backdrop-blur-md rounded-full px-4 py-2 cursor-pointer",
  icon: "w-6 h-6",
};
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  role="link"
  class={`${styles.flex} ${styles.base} ${styles.hover} ${styles.active}`}
>
  {Icon ? <Icon class={styles.icon} /> : null}
  {text}
</a>
