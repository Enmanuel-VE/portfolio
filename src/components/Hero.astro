---
import { Github, Linkedin, Mail } from "@lucide/astro";
const { className } = Astro.props;

/*
Efecto de culumna centrada: w-full max-w-4xl mx-auto px-4
md:max-w-2xl lg:max-w-4xl lg:px-0
*/
---

<section
  class={`${className} w-full h-[100vh] bg-[url('https://images4.alphacoders.com/137/thumb-1920-1374662.png')] bg-no-repeat bg-cover`}
>
  <div
    class="flex flex-col justify-center mx-auto w-full h-full px-4 md:max-w-2xl lg:max-w-4xl lg:px-0"
  >
    <header>
      <h2 class="text-5xl font-bold text-white">Enmanuel Bracho</h2>
      <p class="text-3xl text-gray-400">Frontend Developer</p>
    </header>
    <p class="py-6 max-w-1/2 text-secondary">
      Provident cupiditate voluptatem et in. Quaerat fugiat ut assumenda
      excepturi exercitationem quasi. In deleniti eaque aut repudiandae et a id
      nisi.
    </p>
    <footer class="flex flex-row flex-wrap gap-2">
      <a
        href="https://github.com/Enmanuel-VE"
        target="_blank"
        rel="noopener noreferrer"
        role="link"
        class="flex flex-row justify-center items-center gap-x-2 bg-neutral/50 backdrop-blur-md border border-black/1 hover:border-white rounded-full px-4 py-2 cursor-pointer"
        ><Github /><p>GitHub</p></a
      >
      <a
        href="https://www.linkedin.com/in/enmanuel-villanueva-650182353/"
        target="_blank"
        rel="noopener noreferrer"
        role="link"
        class="flex flex-row justify-center items-center gap-x-2 bg-neutral/50 backdrop-blur-md border border-black/1 hover:border-white rounded-full px-4 py-2 cursor-pointer"
        ><Linkedin /><p>LinkIn</p></a
      >
      <a
        href="mailto:enmanuel02estudios@gmail.com"
        rel="noopener noreferrer"
        role="link"
        class="flex flex-row justify-center items-center gap-x-2 bg-neutral/50 backdrop-blur-md border border-black/1 hover:border-white rounded-full px-4 py-2 cursor-pointer"
        ><Mail /><p>Correo</p></a
      >
    </footer>
  </div>
</section>
